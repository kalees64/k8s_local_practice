# ============================================================
# Root .gitignore — covers both sub-projects:
#   • simple-api  (Node.js / Express, CommonJS)
#   • react-app-3 (React + Vite, ESM)
# ============================================================

# ── Dependencies ────────────────────────────────────────────
node_modules/

# ── Environment & Secrets ────────────────────────────────────
# Never commit real secrets; commit .env.example instead
# .env
# .env.*
# !.env.example
# !.env.*.example

# ── Build Outputs ────────────────────────────────────────────
# Vite / React (react-app-3)
dist/
dist-ssr/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Runtime / Temp ───────────────────────────────────────────
*.local
*.pid
*.seed
*.pid.lock
.cache/
tmp/
temp/

# ── Docker ───────────────────────────────────────────────────
# Keep Dockerfiles and .dockerignore committed;
# ignore any local override files
docker-compose.override.yml
.docker/

# ── Kubernetes ───────────────────────────────────────────────
# Keep deployment YAMLs committed (they are infra-as-code);
# ignore generated / secret manifests
*-secret.yaml
*-secret.yml

# ── OS Artifacts ─────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Editor & IDE ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*.bak

# ── Package manager lockfile conflicts ───────────────────────
# Commit only one lockfile per project; ignore the others
yarn.lock
pnpm-lock.yaml
